---
import BaseLayout from "../../layouts/BaseLayout.astro";

export const prerender = true;

const title = "Contact Request Error | Wisconsin Steel Structures";
const description =
  "There was a problem sending your request. Please go back to the contact form and try again.";
const canonical = "https://yourdomain.com/contact/error/";
---

<BaseLayout title={title} description={description} canonical={canonical} noindex={true}>
  <main id="main-content">
    <section class="error-state">
      <div class="container">
        <a class="back-link" href="/metal-buildings-wisconsin/" aria-label="Back to Metal Buildings Wisconsin page">
          Back to Metal Buildings Wisconsin
        </a>
        <h1>We Couldn&apos;t Send Your Request</h1>
        <p>
          Please return to the contact form and verify your information. If the issue continues, try again in a few minutes.
        </p>
        <a href="/contact/">Back to Contact Form</a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .container {
    width: min(760px, 92%);
    margin: 0 auto;
  }

  .error-state {
    padding: 4rem 0;
  }

  h1 {
    margin: 0 0 0.9rem;
    font-size: clamp(1.8rem, 4vw, 2.4rem);
  }

  .back-link {
    display: inline-block;
    margin-bottom: 0.85rem;
    text-decoration: none;
    font-weight: 600;
  }

  .back-link:hover,
  .back-link:focus-visible {
    text-decoration: underline;
  }
</style>
